# Supabase
# Get these from https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. NEVER expose to the browser. NEVER prefix with NEXT_PUBLIC_.
# Used to write to RLS-protected tables (subscriptions, stripe_*). If this key leaks, anyone
# can read/write your entire database — rotate immediately if exposed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for SEO canonical URLs, sitemap, Stripe redirect URLs.
# In production this should be your live domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (server only except price IDs are not secret but kept server-side in code)
# Developers → API keys (test mode): STRIPE_SECRET_KEY=sk_test_...
# Product catalog → copy Price IDs: price_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
