# Supabase
# Get these from https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. NEVER expose to the browser. NEVER prefix with NEXT_PUBLIC_.
# Used to write to RLS-protected tables (subscriptions). If this key leaks, anyone
# can read/write your entire database — rotate immediately if exposed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for SEO canonical URLs, sitemap, and metadata.
# In production this should be your live domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
